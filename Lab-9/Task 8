#include<stdio.h>
int main(){
	int vibrations=847;
	float temperature=73.6;
	char status='W';
	void *sensor;
	sensor=&vibrations;
	printf("Vibrations=%d\n",*(int*)sensor);
	printf("Address=%p\n",(void*)sensor);
	sensor=&temperature;
	printf("\nTemperature=%.2f\n",*(float*)sensor);
	printf("Address=%p\n",(void*)sensor);
	sensor=&status;
	printf("\nStatus=%c\n",*(char*)sensor);
	printf("Address=%p\n",(void*)sensor);
	
if(*(char*)sensor=='N')
		printf("Alert: Normal\n");
	else if(*(char*)sensor=='W')
		printf("Alert: Warning\n");
	else if(*(char*)sensor=='C')
		printf("Alert: Critical\n");
	else
	printf("Alert: Unknown Status\n");
	return 0;	
}
