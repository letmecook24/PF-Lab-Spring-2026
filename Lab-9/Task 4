#include<stdio.h>
int validatePIN(int storedPIN,int enteredPIN);

int main(){
	int storedPIN=1234,enteredPIN,i;
	for(i=1;i<=3;i++){
		printf("Enter PIN: ");
		scanf("%d",&enteredPIN);
	if(validatePIN(storedPIN,enteredPIN)){
	printf("Access granted. Welcome!\n");
	break;	}
	else{
	printf("Wrong PIN\n");
	if(i<3)
	printf("Attempts left=%d\n",3-i);	}	}
	if(i==4)
	printf("Card blocked. Contact your bank.\n");
return 0;
}
int validatePIN(int storedPIN,int enteredPIN){
if(storedPIN==enteredPIN)
return 1;
else
return 0;
}
