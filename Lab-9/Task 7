#include<stdio.h>
int main(){
	int arr[6],*p=arr,i,highest=0;
	for(i=0;i<6;i++)
{
		printf("Enter marks: ");
		scanf("%d",p+i);	
}
	printf("\nOriginal marks:\n");
	for(i=0;i<6;i++)
		printf("%d ",*(p+i));
	for(i=0;i<6;i++)
{
		if(*(p+i)>highest)
			highest=*(p+i);	
}
	for(i=0;i<6;i++)
	{	*(p+i)=(int)(((float)*(p+i)/highest)*100);	}
	
printf("\nScaled marks:\n");
	for(i=0;i<6;i++)
		printf("%d ",*(p+i));
	return 0;	
}
