#include<stdio.h>
int basicAttack(int dmg,int hp);
int powerStrike(int dmg,int hp);
int heal(int dmg,int hp);
int poisonAttack(int dmg,int hp);

int main(){
	int hp=100,dmg=25,choice,i;
	int (*action)(int,int);
	for(i=0;i<3;i++){
		printf("1.Basic 2.Power 3.Heal 4.Poison\n");
		scanf("%d",&choice);
	if(choice==1)
		action=basicAttack;
	else if(choice==2)
		action=powerStrike;
	else if(choice==3)
		action=heal;
	else
		action=poisonAttack;
	hp=action(dmg,hp);
	printf("HP=%d\n",hp);
}
	return 0;
}
int basicAttack(int dmg,int hp){
	hp=hp-dmg;
	return hp;
}
int powerStrike(int dmg,int hp){
	hp=hp-(dmg*2.5);
	return hp;
}
int heal(int dmg,int hp){
	hp=hp+20;
	return hp;
}
int poisonAttack(int dmg,int hp){
	hp=hp-(dmg/2);
	printf("Poison applied!\n");
	return hp;
}
