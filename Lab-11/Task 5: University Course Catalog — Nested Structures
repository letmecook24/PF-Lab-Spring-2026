#include <stdio.h>
#include <string.h>
struct Department {
    char deptCode[10];
    char deptName[50];
};
struct Course {
    char courseCode[10];
    char courseName[60];
    int creditHours;
    struct Department dept;
};
void showByDept(struct Course c[], int n, char code[]) {
    int i, found = 0;
    for (i = 0; i < n; i++) {
        if (strcmp(c[i].dept.deptCode, code) == 0) {
            printf("\n%s %s %d %s %s\n",
                   c[i].courseCode,
                   c[i].courseName,
                   c[i].creditHours,
                   c[i].dept.deptCode,
                   c[i].dept.deptName);
            found = 1;
        }
    }
    if (found == 0)
        printf("\nNo courses found\n");
}
int main() {
    struct Course c[3];
    int i;
    char code[10];
    for (i = 0; i < 3; i++) {
        printf("\nEnter course code: ");
        scanf("%s", c[i].courseCode);
        printf("Enter course name: ");
        scanf("%s", c[i].courseName);
        printf("Enter credit hours: ");
        scanf("%d", &c[i].creditHours);
        printf("Enter department code: ");
        scanf("%s", c[i].dept.deptCode);
        printf("Enter department name: ");
        scanf("%s", c[i].dept.deptName);	}
    printf("\n");
    for (i = 0; i < 3; i++) {
        printf("%s %s %d %s %s\n\n",
               c[i].courseCode,
               c[i].courseName,
               c[i].creditHours,
               c[i].dept.deptCode,
               c[i].dept.deptName);
    }
    printf("Enter dept code to search: ");
    scanf("%s", code);
    showByDept(c, 3, code);
    return 0;
}
