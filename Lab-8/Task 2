#include<stdio.h>
int main()
{
    int seats[5][6];
    int i,j;
    int available=0;
    int max=0,row=0;
    printf("Enter seat data (0=available,1=booked):\n");
    for(i=0;i<5;i++)
    {
        int count=0;
        for(j=0;j<6;j++)
        {
            scanf("%d",&seats[i][j]);
            if(seats[i][j]==0)
                available++;
            else
                count++;
        }
        if(count>max)
        {
            max=count;
            row=i;
        }
    }
    printf("Available seats = %d\n",available);
    printf("Row with max booked seats = %d",row+1);
    return 0;
}
