#include<stdio.h>
int main()
{
    int a[5][5];
    int r, c,i, j;
    printf("Enter rows and columns: ");
    scanf("%d%d",&r,&c);
    printf("Enter matrix:\n");
    for(i=0;i<r;i++)
    {
        for(j=0;j<c;j++)
        {
            scanf("%d",&a[i][j]);
        }	}
    if(r==c)
        printf("Square Matrix\n");
    else
        printf("Rectangular Matrix\n");
    int isZero=1;
    for(i=0;i<r;i++)
    {
        for(j=0;j<c;j++)
        {
            if(a[i][j]!=0)
                isZero=0;
        }	}
    if(isZero)
        printf("Zero Matrix\n");
    if(r==c)
    {
        int identity=1;
        int diagonal=1;
        int symmetric=1;
        for(i=0;i<r;i++)
        {
            for(j=0;j<c;j++)
            {
                if(i == j && a[i][j] != 1)
                    identity = 0;
                if(i!=j)
                {
                    if(a[i][j]!=0)
                        diagonal=0;
                    if(a[i][j]!=a[j][i])
                        symmetric=0;
                }	}	 }
        if(identity)
            printf("Identity Matrix\n");
        if(diagonal)
            printf("Diagonal Matrix\n");
        if(symmetric)
            printf("Symmetric Matrix\n");
    }
    int upper=1,lower=1;
    for(i=0;i<r;i++)
    {
        for(j=0;j<c;j++)
        {
            if(i>j && a[i][j]!=0)
                upper=0;
            if(i<j && a[i][j]!=0)
                lower=0;
        }	}
    if(upper)
        printf("Upper Triangular Matrix\n");
    if(lower)
        printf("Lower Triangular Matrix\n");
    return 0;
}
